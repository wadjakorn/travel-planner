# Database (Neon / Supabase / local Postgres with PostGIS)
# Local Docker (npm on host):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/travel_planner"
# Inside Docker (docker compose up app) — uses service name, not localhost:
# DATABASE_URL="postgresql://postgres:postgres@db:5432/travel_planner"

# Neon / Supabase (production)
# DATABASE_URL="postgresql://user:password@host:5432/travel_planner"

# Dev bypass — set to "true" to skip Google OAuth (never use in production)
AUTH_BYPASS="false"

# Auth.js
AUTH_SECRET="generate-with-npx-auth-secret"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Google Maps & Routes APIs
GOOGLE_MAPS_API_KEY="your-server-side-api-key"
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-client-side-api-key"
NEXT_PUBLIC_GOOGLE_MAP_ID="your-map-id"
