generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js Models ───────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  trips         Trip[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Domain Models ────────────────────────────────────────

model Trip {
  id         String    @id @default(cuid())
  title      String
  startDate  DateTime
  endDate    DateTime
  userId     String
  shareToken String?   @unique

  // Trip-level arrival / departure (optional)
  arrivalName      String?
  arrivalAddress   String?
  arrivalLat       Float?
  arrivalLng       Float?
  departureName    String?
  departureAddress String?
  departureLat     Float?
  departureLng     Float?

  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  days           TripDay[]
  accommodations Accommodation[]
  nights         NightAccommodation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model TripDay {
  id                String      @id @default(cuid())
  date              DateTime    @db.Date
  sortOrder         Int
  tripId            String
  defaultTravelMode TravelMode  @default(CAR)
  trip              Trip        @relation(fields: [tripId], references: [id], onDelete: Cascade)
  spots             Spot[]

  @@index([tripId])
}

model Spot {
  id               String     @id @default(cuid())
  name             String
  placeId          String?
  lat              Float
  lng              Float
  type             SpotType
  address          String?
  notes            String?
  sortOrder        Int
  stayMinutes      Int        @default(60)
  travelModeToNext TravelMode?
  tripDayId        String
  tripDay          TripDay    @relation(fields: [tripDayId], references: [id], onDelete: Cascade)

  @@index([tripDayId])
}

model Accommodation {
  id      String  @id @default(cuid())
  name    String
  address String?
  lat     Float
  lng     Float
  placeId String?
  tripId  String
  trip    Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  nights  NightAccommodation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId])
}

/// One record per night of the trip. date = the night's start date
/// (e.g. Apr 13 = the night between Apr 13 and Apr 14).
model NightAccommodation {
  id              String         @id @default(cuid())
  date            DateTime       @db.Date
  tripId          String
  accommodationId String?
  trip            Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  accommodation   Accommodation? @relation(fields: [accommodationId], references: [id], onDelete: SetNull)

  @@unique([tripId, date])
  @@index([tripId])
}

// ─── Enums ────────────────────────────────────────────────

enum SpotType {
  ATTRACTION
  HOTEL
  RESTAURANT
  CAFE
  SHOPPING
  TRANSPORT
  CUSTOM
}

enum TravelMode {
  CAR
  WALK
  TRANSIT
  BICYCLE
}
