{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js dev",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "/bin/zsh",
      "runtimeArgs": ["-i", "-c", "npm run dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "Docker dev",
      "runtimeExecutable": "/bin/zsh",
      "runtimeArgs": ["-i", "-c", "PATH=/Users/user/.rd/bin:$PATH docker compose up app"],
      "port": 3000
    },
    {
      "name": "PostgreSQL (Docker)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up"],
      "port": 5432
    }
  ]
}
